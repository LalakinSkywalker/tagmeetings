# =============================================================================
# TagMeetings — Plantilla de variables de entorno
# -----------------------------------------------------------------------------
# La forma facil de llenar esto es correr:  node setup.mjs  (genera las llaves
# de seguridad por ti y te pide las demas con sus links).
#
# Si prefieres a mano: copia este archivo a `.env.local` y rellena los valores.
# El .env.local esta en .gitignore y NUNCA debe subirse a un repo.
# =============================================================================

# --- Tu sitio -----------------------------------------------------------------
# En tu computadora: http://localhost:3050  |  En produccion: tu dominio https.
NEXT_PUBLIC_SITE_URL=http://localhost:3050

# --- Supabase (base de datos + login) · OBLIGATORIO ---------------------------
# Crea un proyecto en https://supabase.com/dashboard/projects
# Las 3 llaves estan en: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-publishable-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# --- Deepgram (transcripcion de audio) · OBLIGATORIO --------------------------
# API Key en https://console.deepgram.com
DEEPGRAM_API_KEY=tu-deepgram-api-key

# --- OpenRouter (analisis + chat con IA) · OBLIGATORIO ------------------------
# API Key en https://openrouter.ai/keys
OPENROUTER_API_KEY=tu-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-5-mini

# --- Cloudflare R2 (almacen de audios, hasta 2 GB) · OBLIGATORIO --------------
# Panel: https://dash.cloudflare.com → R2. Crea un bucket y un API Token de R2.
R2_ACCOUNT_ID=tu-account-id
R2_ENDPOINT=https://tu-account-id.r2.cloudflarestorage.com
R2_BUCKET=tagmeetings-audios
R2_ACCESS_KEY_ID=tu-r2-access-key-id
R2_SECRET_ACCESS_KEY=tu-r2-secret-access-key

# --- Llaves de seguridad · OBLIGATORIO (las genera setup.mjs por ti) ----------
# ENCRYPTION_KEY: 32 bytes en base64 o hex. Genera con: openssl rand -base64 32
# CRON_SECRET: cualquier cadena aleatoria larga. Genera con: openssl rand -hex 24
ENCRYPTION_KEY=
CRON_SECRET=

# --- OpenAI · OPCIONAL --------------------------------------------------------
# Dejala VACIA para que los embeddings del chat-con-citas usen OpenRouter (una
# llave menos). Ponla solo si prefieres tu cuenta de OpenAI directa.
OPENAI_API_KEY=

# --- Google Drive · OPCIONAL (respaldo de audios) -----------------------------
# Credenciales OAuth 2.0 (tipo "Aplicacion web") en:
# https://console.cloud.google.com/apis/credentials
# Redirect URI autorizado: <NEXT_PUBLIC_SITE_URL>/api/drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Notificaciones push · OPCIONAL -------------------------------------------
# Las llaves VAPID las genera setup.mjs. Para ACTIVAR el push, pon tu correo en
# VAPID_SUBJECT (formato mailto:tucorreo@dominio.com). Sin el, el push queda
# desactivado de forma limpia y la app funciona igual.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- Desarrollo / pruebas · OPCIONAL ------------------------------------------
# USE_MOCK_PROVIDERS=true usa proveedores simulados (sin gastar en APIs reales).
# DEEPGRAM_WEBHOOK_BASE_URL: solo si usas el callback async de Deepgram (HTTPS).
# USE_MOCK_PROVIDERS=false
# DEEPGRAM_WEBHOOK_BASE_URL=
